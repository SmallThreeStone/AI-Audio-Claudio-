# AI 服务
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 天气（可选，留空则禁用天气播报）
OPENWEATHER_API_KEY=

# TTS 引擎：edge（免费免注册）或 fish（Fish Audio，需注册）
TTS_PROVIDER=edge

# Demo 模式：新用户无歌单时可体验 TTS 版电台
DEMO_MODE=true

# 前端地址（用于 OAuth 回调等）
FRONTEND_URL=http://your-server-ip:7236
